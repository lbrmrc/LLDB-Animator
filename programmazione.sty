\newenvironment<>{codeblock}[1]{%
\setbeamercolor{block title}{fg=white,bg=orange!75!black}%
\begin{block}#2{#1}}{\end{block}}

\newcommand{\codelink}[1]{\texttt{
  \href{\noexpand \urlesempi \outname/#1}{\outname/#1}}}

\newcommand{\codeexample}[2][numbers=left,language=C,breaklines=true]{
    \begin{codeblock}{\codelink{#2}}
     \lstinputlisting[#1]{"\diresempi \outname/#2"}
    \end{codeblock}}

\newcommand{\adjustcodeexample}[3][numbers=left,language=C]{
  \begin{codeblock}{\codelink{#2}}
    \begin{adjustbox}{width=11.0cm,height={#3},keepaspectratio}
      \lstinputlisting[#1]{"\diresempi \outname/#2"}
    \end{adjustbox}
  \end{codeblock}}
%\diresempi \outname/{#1}}

\newenvironment{exercisedir}[1]
{\StrSubstitute{#1}{ }{_}[\name]
  \edef\tmp{\lowercase{\noexpand\href{\urlesempi \outname/\name/}}}
\begin{block}{\tmp{#1}}}
{\end{block}}

\newenvironment{exercise}[1]
{\StrSubstitute{#1}{ }{-}[\name]
  \edef\tmp{\lowercase{\noexpand\href{\urlesempi \outname/\name.c}}}
\begin{block}{\tmp{#1}}}
{\end{block}}





\newcommand{\codefromfile}[3]{\lstinputlisting[firstline={#2},lastline={#3},language=C,]{#1}}

\newcommand{\sourceframe}[2]
{\begin{frame}{#1}
    \lstinputlisting[escapeinside={/*}{*/}]{#2}
\end{frame}}

\newcommand{\nsourceframe}[2]
{\begin{frame}{#1}
    \codeexample{#2}
\end{frame}}

\newcommand{\codeframe}[4]
{\begin{frame}{#1}
    \codefromfile{#2}{#3}{#4}
\end{frame}}

